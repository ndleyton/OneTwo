<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="false"
    android:overScrollMode="ifContentScrolls">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/timer_settings_card"
        style="?attr/materialCardViewElevatedStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        app:cardBackgroundColor="?attr/colorSurfaceContainer"
        app:cardElevation="8dp"
        app:strokeWidth="0dp"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.OneTwo.ExtraLarge">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingTop="32dp"
            android:paddingEnd="28dp"
            android:paddingBottom="28dp">

            <TextView
                android:id="@+id/dialog_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                android:gravity="center"
                android:text="@string/timer_settings_title"
                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                android:textColor="?attr/colorPrimary" />

            <LinearLayout
                android:id="@+id/timer_count_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                android:gravity="center_vertical"
                android:minHeight="56dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/timer_count_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/timer_count_label"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    android:textColor="?attr/colorOnSurface" />

                <NumberPicker
                    android:id="@+id/timer_count_picker"
                    android:layout_width="96dp"
                    android:layout_height="wrap_content"
                    android:theme="@style/ThemeOverlay.Material3.MaterialAlertDialog" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/base_time_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                android:gravity="center_vertical"
                android:minHeight="56dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/base_time_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/timer_base_time_label"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    android:textColor="?attr/colorOnSurface" />

                <LinearLayout
                    android:id="@+id/base_time_picker_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <NumberPicker
                        android:id="@+id/minute_picker"
                        android:layout_width="82dp"
                        android:layout_height="wrap_content"
                        android:theme="@style/ThemeOverlay.Material3.MaterialAlertDialog" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="2dp"
                        android:layout_marginEnd="2dp"
                        android:text="@string/colon"
                        android:textAppearance="?attr/textAppearanceHeadlineSmall"
                        android:textColor="?attr/colorPrimary" />

                    <NumberPicker
                        android:id="@+id/seconds_picker"
                        android:layout_width="82dp"
                        android:layout_height="wrap_content"
                        android:theme="@style/ThemeOverlay.Material3.MaterialAlertDialog" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/increment_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                android:gravity="center_vertical"
                android:minHeight="56dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/increment_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/timer_increment_label"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    android:textColor="?attr/colorOnSurface" />

                <LinearLayout
                    android:id="@+id/increment_picker_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <NumberPicker
                        android:id="@+id/increment_minute_picker"
                        android:layout_width="82dp"
                        android:layout_height="wrap_content"
                        android:theme="@style/ThemeOverlay.Material3.MaterialAlertDialog" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="2dp"
                        android:layout_marginEnd="2dp"
                        android:text="@string/colon"
                        android:textAppearance="?attr/textAppearanceHeadlineSmall"
                        android:textColor="?attr/colorPrimary" />

                    <NumberPicker
                        android:id="@+id/increment_seconds_picker"
                        android:layout_width="82dp"
                        android:layout_height="wrap_content"
                        android:theme="@style/ThemeOverlay.Material3.MaterialAlertDialog" />
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/apply_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="54dp"
                android:text="@string/timer_settings_apply"
                android:textColor="?attr/colorOnPrimary"
                app:backgroundTint="?attr/colorPrimary"
                app:cornerRadius="@dimen/shape_corner_soft" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/cancel_button"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:minHeight="54dp"
                android:text="@string/cancel"
                app:cornerRadius="@dimen/shape_corner_soft" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</ScrollView>
