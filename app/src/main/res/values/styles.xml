<resources>

    <style name="AppTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:fontFamily">@font/inter</item>
        <item name="fontFamily">@font/inter</item>
        <item name="colorPrimary">@color/m3_primary</item>
        <item name="colorOnPrimary">@color/m3_on_primary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorPrimaryContainer">@color/m3_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/m3_on_primary_container</item>
        <item name="colorSecondary">@color/m3_secondary</item>
        <item name="colorOnSecondary">@color/m3_on_secondary</item>
        <item name="colorSecondaryContainer">@color/m3_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/m3_on_secondary_container</item>
        <item name="colorTertiary">@color/m3_tertiary</item>
        <item name="colorOnTertiary">@color/m3_on_tertiary</item>
        <item name="colorTertiaryContainer">@color/m3_tertiary_container</item>
        <item name="colorOnTertiaryContainer">@color/m3_on_tertiary_container</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:colorAccent">@color/colorAccent</item>
        <item name="android:colorBackground">@color/m3_background</item>
        <item name="colorOnBackground">@color/m3_on_background</item>
        <item name="colorSurface">@color/m3_surface</item>
        <item name="colorOnSurface">@color/m3_on_surface</item>
        <item name="colorSurfaceVariant">@color/m3_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/m3_on_surface_variant</item>
        <item name="colorSurfaceContainer">@color/m3_surface_container</item>
        <item name="colorSurfaceContainerHigh">@color/m3_surface_container_high</item>
        <item name="colorOutline">@color/m3_outline</item>
        <item name="colorOutlineVariant">@color/m3_outline_variant</item>
        <item name="colorSurfaceInverse">@color/m3_inverse_surface</item>
        <item name="colorOnSurfaceInverse">@color/m3_inverse_on_surface</item>
        <item name="colorPrimaryInverse">@color/m3_inverse_primary</item>
        <item name="colorError">@color/m3_error</item>
        <item name="colorOnError">@color/m3_on_error</item>
        <item name="colorErrorContainer">@color/m3_error_container</item>
        <item name="colorOnErrorContainer">@color/m3_on_error_container</item>
        <item name="android:statusBarColor">@color/m3_primary</item>
        <item name="android:navigationBarColor">@color/m3_surface</item>
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.OneTwo.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.OneTwo.Container</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.OneTwo.Large</item>
        <item name="shapeAppearanceCornerSmall">@style/ShapeAppearance.OneTwo.Small</item>
        <item name="shapeAppearanceCornerMedium">@style/ShapeAppearance.OneTwo.Container</item>
        <item name="shapeAppearanceCornerLarge">@style/ShapeAppearance.OneTwo.Large</item>
        <item name="shapeAppearanceCornerExtraLarge">@style/ShapeAppearance.OneTwo.ExtraLarge</item>
    </style>

    <style name="ShapeAppearance.OneTwo.Small" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ShapeAppearance.OneTwo.Container" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/shape_corner_soft</item>
    </style>

    <style name="ShapeAppearance.OneTwo.DiceSummary" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">18dp</item>
    </style>

    <style name="ShapeAppearance.OneTwo.DiceTile" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ShapeAppearance.OneTwo.Large" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/shape_corner_large</item>
    </style>

    <style name="ShapeAppearance.OneTwo.ExtraLarge" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/shape_corner_extra_large</item>
    </style>

    <style name="Widget.OneTwo.FilledIconButton" parent="Widget.Material3.Button.IconButton">
        <item name="iconTint">?attr/colorPrimary</item>
    </style>

    <style name="Widget.OneTwo.DeleteIconButton" parent="Widget.Material3.Button.IconButton.Filled">
        <item name="iconTint">@color/m3_on_tertiary</item>
        <item name="backgroundTint">@color/secondAccent</item>
    </style>

</resources>
